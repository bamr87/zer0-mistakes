{
  // ==================================================
  // UNIFIED VS CODE LAUNCH CONFIGURATION - Docker-First
  // ==================================================
  // Optimized for zer0-mistakes Jekyll theme development
  // Last Updated: 2026-03-22
  
  "version": "0.2.0",
  "configurations": [
    
    // ==========================================
    // DOCKER DEVELOPMENT CONFIGURATIONS
    // ==========================================
    {
      "name": "🚀 Debug Zer0-Mistakes Theme (Docker)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Docker: Compose Up (Detached)",
      "postDebugTask": "Docker: Compose Stop",
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--disable-web-security",
        "--disable-features=VizDisplayCompositor"
      ],
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"],
      "internalConsoleOptions": "openOnSessionStart",
      "trace": true,
      "pathMapping": {
        "/": "${workspaceFolder}/_site/",
        "/assets/": "${workspaceFolder}/assets/",
        "/js/": "${workspaceFolder}/assets/js/",
        "/css/": "${workspaceFolder}/assets/css/"
      }
    },

    {
      "name": "🔗 Attach to Running Jekyll Theme (Docker)",
      "type": "msedge", 
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"],
      "internalConsoleOptions": "openOnSessionStart",
      "urlFilter": "localhost:4000*",
      "trace": true,
      "pathMapping": {
        "/": "${workspaceFolder}/_site/",
        "/assets/": "${workspaceFolder}/assets/",
        "/js/": "${workspaceFolder}/assets/js/",
        "/css/": "${workspaceFolder}/assets/css/"
      }
    },

    {
      "name": "🔄 Docker Rebuild & Debug Theme",
      "type": "msedge",
      "request": "launch", 
      "url": "http://localhost:4000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Docker: Rebuild (Force)",
      "postDebugTask": "Docker: Compose Down",
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--disable-web-security",
        "--auto-open-devtools-for-tabs"
      ],
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"],
      "internalConsoleOptions": "openOnSessionStart",
      "trace": true,
      "pathMapping": {
        "/": "${workspaceFolder}/_site/",
        "/assets/": "${workspaceFolder}/assets/",
        "/js/": "${workspaceFolder}/assets/js/",
        "/css/": "${workspaceFolder}/assets/css/"
      }
    },

    // ==========================================
    // GEM DEVELOPMENT CONFIGURATIONS
    // ==========================================
    // NOTE: Gem release operations are handled via VS Code Tasks
    // Use Cmd+Shift+P → "Tasks: Run Task" and select:
    // - "🚀 Release: Patch" for patch releases
    // - "🚀 Release: Minor" for minor releases  
    // - "🚀 Release: Major" for major releases
    // - "🔍 Release: Dry Run Preview" to preview changes
    // The tasks use the modular release script at scripts/release

    // ==========================================
    // MOBILE & RESPONSIVE TESTING
    // ==========================================
    {
      "name": "📱 Mobile Debug (Docker)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Docker: Compose Up (Detached)",
      "postDebugTask": "Docker: Compose Stop",
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--device-scale-factor=2",
        "--force-device-scale-factor=2",
        "--user-agent=Mozilla/5.0 (iPhone; CPU iPhone OS 15_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/15.0 Mobile/15E148 Safari/604.1"
      ],
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"],
      "internalConsoleOptions": "openOnSessionStart",
      "trace": true,
      "pathMapping": {
        "/": "${workspaceFolder}/_site/",
        "/assets/": "${workspaceFolder}/assets/",
        "/js/": "${workspaceFolder}/assets/js/",
        "/css/": "${workspaceFolder}/assets/css/"
      }
    },

    // ==========================================
    // PERFORMANCE DEBUGGING
    // ==========================================
    {
      "name": "🎯 Performance Debug (Docker)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Docker: Compose Up (Detached)",
      "postDebugTask": "Docker: Compose Stop",
      "runtimeArgs": [
        "--remote-debugging-port=9222",
        "--enable-logging=stderr",
        "--log-level=0",
        "--enable-features=NetworkService,NetworkServiceLogging"
      ],
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"],
      "internalConsoleOptions": "openOnSessionStart",
      "trace": true,
      "pathMapping": {
        "/": "${workspaceFolder}/_site/",
        "/assets/": "${workspaceFolder}/assets/",
        "/js/": "${workspaceFolder}/assets/js/",
        "/css/": "${workspaceFolder}/assets/css/"
      }
    }
  ]
}
