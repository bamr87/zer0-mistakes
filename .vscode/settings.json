{
  // ==================================================
  // UNIFIED VS CODE SETTINGS - Docker-First Development
  // ==================================================
  // Optimized for zer0-mistakes Jekyll theme development
  // Last Updated: 2026-06-21

  // ==========================================
  // GITHUB COPILOT CONFIGURATION
  // ==========================================
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "yaml": true,
    "liquid": true,
    "html": true,
    "scss": true,
    "javascript": true,
    "python": true,
    "dockerfile": true,
    "json": true,
    "jsonc": true
  },

  // ==========================================
  // FILE ASSOCIATIONS & LANGUAGE SUPPORT
  // ==========================================
  "files.associations": {
    "*.html": "liquid",
    "*.md": "markdown",
    "*.yml": "yaml",
    "*.yaml": "yaml",
    "_config*.yml": "yaml",
    "docker-compose*.yml": "yaml",
    "Dockerfile*": "dockerfile"
  },

  // ==========================================
  // EDITOR CONFIGURATION
  // ==========================================
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true
  },
  "editor.tabCompletion": "on",
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.minimap.enabled": false,
  "editor.fontSize": 14,
  "editor.lineHeight": 26,

  // ==========================================
  // MARKDOWN CONFIGURATION
  // ==========================================
  "[markdown]": {
    "editor.fontSize": 14,
    "editor.lineHeight": 26,
    "editor.wordWrapColumn": 80,
    "editor.lineNumbers": "on",
    "editor.wordWrap": "bounded",
    "editor.minimap.enabled": false
  },
  "markdown.preview.breaks": true,
  "markdown.preview.linkify": true,

  // ==========================================
  // YAML CONFIGURATION
  // ==========================================
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced"
  },
  "yaml.format.enable": true,
  "yaml.completion": true,
  "yaml.hover": true,
  "yaml.validate": true,
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": [
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml"
    ],
    "https://json.schemastore.org/github-action.json": [
      ".github/actions/*/action.yml",
      ".github/actions/*/action.yaml"
    ]
  },

  // ==========================================
  // LIQUID TEMPLATE CONFIGURATION
  // ==========================================
  "[liquid]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "liquid.format.enable": true,
  "emmet.includeLanguages": {
    "liquid": "html"
  },

  // ==========================================
  // RUBY CONFIGURATION (Shopify Ruby LSP)
  // ==========================================
  "[ruby]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "rubyLsp.formatter": "auto",

  // ==========================================
  // SCSS / JSON / SHELL CONFIGURATION
  // ==========================================
  "[scss]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[shellscript]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  // ==========================================
  // DOCKER / CONTAINERS CONFIGURATION
  // ==========================================
  "containers.images.label": "Tag",
  "containers.composeCommand": "docker-compose",

  // ==========================================
  // SHELLCHECK (timonwong.shellcheck)
  // ==========================================
  "shellcheck.enable": true,
  "shellcheck.run": "onType",
  "shellcheck.useWorkspaceRootAsCwd": true,

  // ==========================================
  // TERMINAL CONFIGURATION
  // ==========================================
  "terminal.integrated.env.osx": {
    "JEKYLL_ENV": "development",
    "DOCKER_BUILDKIT": "1"
  },
  "terminal.integrated.env.linux": {
    "JEKYLL_ENV": "development",
    "DOCKER_BUILDKIT": "1"
  },

  // ==========================================
  // FILE WATCHING & PERFORMANCE
  // ==========================================
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/_site/**": true,
    "**/.sass-cache/**": true,
    "**/.jekyll-cache/**": true,
    "/vendor/**": true,
    "**/__pycache__/**": true,
    "**/*.pyc": true,
    "**/venv/**": true,
    "**/env/**": true,
    "**/build/**": true,
    "**/*.gem": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/_site": true,
    "**/.sass-cache": true,
    "**/.jekyll-cache": true,
    "**/build": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/_site": true,
    "/vendor": true,
    "**/__pycache__": true,
    "**/build": true
  },

  // ==========================================
  // AUTO-SAVE & LIVE RELOAD
  // ==========================================
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  // ==========================================
  // SPELL CHECKING
  // ==========================================
  "cSpell.words": [
    "bamr",
    "barodybroject",
    "buildkit",
    "commonmarker",
    "endcapture",
    "endraw",
    "frontmatter",
    "gemspec",
    "Groking",
    "Inkscape",
    "Jamstack",
    "Krita",
    "lastmod",
    "livereload",
    "markdownify",
    "MERN",
    "parodynews",
    "Picade",
    "posthog",
    "rubocop",
    "rubygems",
    "sublinks",
    "webrick",
    "wikilinks",
    "winget",
    "zer0"
  ]
}
