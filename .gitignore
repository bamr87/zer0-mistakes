node_modules/
assets/css/vendor/bootstrap-from-npm.css

# Playwright styling / visual run output
test/visual-results/

_site/
_site_proxycheck/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
# Ignore folders generated by Bundler (root only — assets/vendor/ is committed)
.bundle/
/vendor/
.vendor/
# Note: We COMMIT Gemfile.lock for reproducible builds
# See: docs/systems/ZERO_PIN_STRATEGY.md

# Node
node_modules/

# OS files
*.DS_Store

# Environment files (NEVER commit secrets!)
.env
.env.local
.env.*.local
*.env
!.env.example
env-variables.log

# Gem development
*.gem
pkg/
tmp/
.rspec_status

# Test framework results and reports
test/results/*.json
test/reports/*
test/coverage/*
logs/*

# Front Matter CMS
.frontmatter/

# VS Code / Cursor js-debug browser profiles (see .vscode/launch.json userDataDir)
.vscode/chrome-debug-profile/
.vscode/chrome-debug-profile-mobile/
.vscode/edge-debug-profile/

# Python cache
**/__pycache__/
*.pyc
*.pyo

# Obsidian — keep shared config (.obsidian/app.json, core-plugins.json, etc.)
# but ignore per-user runtime/cache state.
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json
.obsidian/themes/
.obsidian/snippets/

# Obsidian working files that should not be published by Jekyll
*.canvas
*.excalidraw.md

# --- Obsidian (vault local-only state) -------------------------------------
# We commit a curated subset of `.obsidian/` (app, core-plugins, etc.) so the
# vault opens with consistent settings, but ignore Obsidian's per-user state.
# See pages/_docs/obsidian/getting-started.md for the rationale.
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspaces.json
.obsidian/cache
.obsidian/graph.json
.obsidian/plugins/*/data.json
.obsidian/plugins/*/main.js
.obsidian/plugins/*/manifest.json
.obsidian/plugins/*/styles.css
.trash/
