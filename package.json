{
  "name": "zer0-mistakes-theme-tools",
  "version": "1.17.1",
  "private": true,
  "description": "Theme tooling: Playwright tests; vendor:mermaid copies Mermaid from node_modules (no jsDelivr); optional css:bootstrap for advanced Bootstrap SCSS. Committed assets/vendor/ is GitHub Pages–safe.",
  "scripts": {
    "vendor:install": "bash scripts/vendor-install.sh",
    "vendor:mermaid": "mkdir -p assets/vendor/mermaid && cp node_modules/mermaid/dist/mermaid.min.js assets/vendor/mermaid/mermaid.min.js",
    "css:bootstrap": "mkdir -p assets/css/vendor && sass --load-path=node_modules --no-source-map --style=compressed assets/css/theme-npm-entry.scss:assets/css/vendor/bootstrap-from-npm.css",
    "test:smoke": "playwright test --config=test/playwright.config.js --project=smoke",
    "test:snapshots": "playwright test --config=test/playwright.config.js --project=snapshots",
    "test:regression": "playwright test --config=test/playwright.config.js --project=regression-chromium --project=regression-firefox --project=regression-webkit",
    "test:update-snapshots": "playwright test --config=test/playwright.config.js --project=snapshots --update-snapshots"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.49.0",
    "bootstrap": "5.3.3",
    "mermaid": "10.9.6",
    "sass": "^1.80.0"
  }
}
