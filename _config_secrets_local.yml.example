# Example local AI chat configuration template.
# Copy to _config_secrets_local.yml and populate with your actual values.
# Do NOT commit the real file — it is listed in .gitignore.
ai_chat:
  enabled: false
  proxy_ready: false
  auth_mode: 'proxy'
  api_key: ''
  endpoint: 'http://localhost:PORT/v1/chat/completions'
