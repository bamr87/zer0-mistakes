# Zer0-Mistakes Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Docker Hub Configuration (for local publishing)
# ===========================================

# Docker Hub credentials
# Get your access token at: https://hub.docker.com/settings/security
DOCKER_USERNAME=your-dockerhub-username
DOCKER_TOKEN=dckr_pat_your-access-token-here

# Docker image name (your Docker Hub repository)
DOCKER_IMAGE=your-username/zer0-mistakes

# ===========================================
# Repository Configuration
# ===========================================

# Repository name for jekyll-github-metadata gem
# Format: owner/repo
PAGES_REPO_NWO=bamr87/zer0-mistakes

# ===========================================
# AI Chat Assistant (Claude)
# ===========================================

# The chat assistant authenticates to Claude on the chat proxy, never in the
# static site. For LOCAL DEV, set a credential here and run the dev proxy:
#   node --env-file=.env templates/deploy/chat-proxy/dev-proxy.mjs
# For PUBLIC deploys, set the credential as a Worker secret instead
# (`wrangler secret put ...`, see templates/deploy/chat-proxy/).

# --- Local development: Claude Code OAuth token (recommended) ---
# Long-lived token from `claude setup-token` (Claude Pro/Max). The dev proxy
# sends it as a Bearer token. Personal credential — keep it in .env (git-ignored).
# ALSO used by the preview-image generator's Claude orchestration (article
# analysis + image review, scripts/generate-preview-images.sh) — one token
# covers both.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-your-claude-code-token-here

# --- Public deploy (or alternative local): Anthropic API key ---
# Get a key at https://console.anthropic.com/ . If both are set, the OAuth
# token wins. For a public site, set this as the Worker secret ANTHROPIC_API_KEY
# (a workspace-scoped key with a spend cap is recommended).
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# GitHub token for proxy-mode chat actions (issues / pull requests).
# Fine-grained PAT scoped to this repository with Issues, Contents and
# Pull requests read-write. Optional — `url` mode needs no token.
# GITHUB_TOKEN=github_pat_your-token-here

# ===========================================
# Installer AI (scripts/bin/install wizard/suggest/diagnose)
# ===========================================
# The AI installer is multi-provider. By default it AUTO-detects, preferring the
# logged-in `claude` CLI (Claude Code OAuth) → CLAUDE_CODE_OAUTH_TOKEN /
# ANTHROPIC_API_KEY (above) → OPENAI_API_KEY (below). Override the choice:
#   ZER0_AI_PROVIDER=auto        # auto | claude-cli | anthropic | openai | none
#   ZER0_AI_MODEL=claude-sonnet-5
# ZER0_NO_AI=1 disables every AI codepath (rule-based fallbacks only).
# Keys are read from the environment ONLY — never from a config file or flag.

# ===========================================
# AI Image Generation (for preview images)
# ===========================================
# Claude ORCHESTRATES (analyzes each article into an art brief, then reviews
# the rendered image) using the Claude credential above — or a logged-in
# `claude` CLI. The image itself is RENDERED by the provider below
# (default: openai — set the matching key).

# OpenAI API Key (default renderer: gpt-image-2 / DALL-E + --enhance mode)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Stability AI API Key (Stable Diffusion)
# Get your key at: https://platform.stability.ai/account/keys
STABILITY_API_KEY=sk-your-stability-api-key-here

# xAI API Key (grok-2-image)
# Get your key at: https://console.x.ai/
# XAI_API_KEY=xai-your-xai-api-key-here

# Google Gemini API Key (gemini-2.5-flash-image)
# Get your key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# Image generation settings
# NOTE: Default settings are now in _config.yml under 'preview_images' section
# These environment variables override config file settings if set
# Uncomment to override:
# IMAGE_STYLE="retro pixel art, 8-bit video game aesthetic"
# IMAGE_SIZE="1536x1024"
# IMAGE_MODEL="gpt-image-2"
# IMAGE_QUALITY="auto"

# ===========================================
# Jekyll/Site Configuration (optional)
# ===========================================

# Jekyll environment
JEKYLL_ENV=development

# ===========================================
# Analytics (optional)
# ===========================================

# PostHog API Key (if using PostHog analytics)
# POSTHOG_API_KEY=phc_your-posthog-key-here
